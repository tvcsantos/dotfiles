# Only for interactive shells
[[ -o interactive ]] || return

# 1) Interactive env (non-secret)
for f in "$ZDOTDIR/env/interactive/"*.zsh(N); do
  source "$f"
done

# 2) Pre-OMZ settings (must be set BEFORE sourcing OMZ)
for f in "$ZDOTDIR/pre-omz/"*.zsh(N); do
  source "$f"
done

# 3) Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
plugins=(git kubectl mvn evalcache direnv gradle aws)
source "$ZSH/oh-my-zsh.sh"

# 4) Post-OMZ ordered init
for f in "$ZDOTDIR/init/"*.zsh(N); do
  source "$f"
done

# 5) Features (unordered; each file should guard its own inits)
for f in "$ZDOTDIR/features/"*.zsh(N); do
  source "$f"
done

# 6) Platform UX tweaks (non-env) — global + OS + host

# Global platform helpers
_pa="$ZDOTDIR/platform/aliases.zsh"
_pt="$ZDOTDIR/platform/tools.zsh"
[[ -r "$_pa" ]] && source "$_pa"
[[ -r "$_pt" ]] && source "$_pt"
unset _pa _pt

# OS-specific platform helpers
case "$OSTYPE" in
  darwin*) _pc="$ZDOTDIR/platform/darwin.zsh" ;;
  linux*)  _pc="$ZDOTDIR/platform/linux.zsh"  ;;
esac
[[ -r "$_pc" ]] && source "$_pc"
unset _pc

# 7) Zsh UX overrides by host (non-env tweaks)
_hc="$ZDOTDIR/platform/host-$(hostname -s).zsh"
[[ -r "$_hc" ]] && source "$_hc"
unset _hc

# 8) Interactive-only secrets
_si="$ZDOTDIR/env/secrets/interactive.zsh"
[[ -r "$_si" ]] && source "$_si"
unset _si

# 9) Interactive-only host-specific secrets
_sih="$ZDOTDIR/env/secrets/interactive-host-$(hostname -s).zsh"
[[ -r "$_sih" ]] && source "$_sih"
unset _sih